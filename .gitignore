*.so
*.dylib
*.test
*.out

# Go workspace file
go.work
go.work.sum

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ArchiteX audit bundles (generated by `architex report --out`) and any
# scratch output dirs the selftest writes (e.g. .architex-<scenario>-test/).
.architex/
.architex-*/
tmp_audit/

# GoReleaser local build output
dist/

# Real-world validation harness output (`scripts/validate-real-world.ps1`)
# Contains shallow clones of upstream Terraform repos plus per-run logs;
# runs to GiB-scale on a full top-50 sweep, never appropriate to commit.
.validation-runs/

# Internal dev notes (intentionally not published)
# llm.md is the maintainer's onboarding/context journal -- it documents
# weak spots, design trade-offs, and not-yet-built work that aren't
# appropriate for the public repo. Keep it on disk, do not commit it.
llm.md
